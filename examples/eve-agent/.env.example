# Eve agent service environment variables
# Copy to .env and fill in the values before running.

# Port this service listens on (default: 3099)
PORT=3099

# Shared HMAC secret — must match EVE_WEBHOOK_SECRET in your Hogsend deployment.
# Generate one: openssl rand -base64 32
EVE_WEBHOOK_SECRET=

# Base URL of the Hogsend API this service posts callbacks to.
HOGSEND_API_URL=http://localhost:3002

# Override the full callback URL (optional — defaults to HOGSEND_API_URL/v1/webhooks/eve)
# HOGSEND_CALLBACK_URL=https://your-hogsend-api.railway.app/v1/webhooks/eve

# Simulated HITL review delay in milliseconds (default: 2000)
# Increase this to give yourself time to approve in a real HITL scenario.
HITL_DELAY_MS=2000
