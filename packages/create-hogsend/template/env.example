# Core (required at boot)
NODE_ENV=development
PORT=3002
LOG_LEVEL=debug

# Database — local Docker Timescale on port 5434 (see docker-compose.yml)
DATABASE_URL=postgresql://hogsend:hogsend@localhost:5434/hogsend

# Redis — local Docker on port 6380 (PostHog property cache)
REDIS_URL=redis://localhost:6380

# Local Docker host ports. The bootstrap script auto-remaps these (and the URLs
# above) when a port is already taken, so multiple stacks can run side by side.
# POSTGRES_PORT=5434
# REDIS_PORT=6380
# HATCHET_DASHBOARD_PORT=8888
# HATCHET_GRPC_PORT=7077

# Auth secret — REQUIRED, minimum 32 characters.
# The bootstrap script generates a real one for you; below is a placeholder.
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3002

# First-admin bootstrap (or use `hogsend studio admin create`). Public sign-up is
# closed, so the first Studio admin is created from the server. Set
# STUDIO_ADMIN_EMAIL and, on a zero-user DB, the API mints it on boot. If you omit
# STUDIO_ADMIN_PASSWORD, a strong one is generated and printed ONCE to the log —
# rotate it via the Studio forgot/reset flow.
# STUDIO_ADMIN_EMAIL=admin@example.com
# STUDIO_ADMIN_PASSWORD=

# Resend — REQUIRED for email sends
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@example.com

# Sending domain — the domain your emails send from. `create-hogsend --domain`
# fills these in; otherwise uncomment + set them, then register + verify the
# domain with `hogsend domain add <domain>` (DNS records, panel deep link,
# optional auto-apply) and `hogsend domain check`.
# EMAIL_FROM=hello@example.com
# EMAIL_DOMAIN=example.com
#
# Test mode — while your sending domain isn't verified yet, redirect EVERY send
# to a safe inbox instead of the real recipient (subject prefixed `[TEST → …]`).
#   auto  (default) — on automatically while EMAIL_DOMAIN is set + unverified,
#                     off the moment it verifies. Fails OPEN (a provider outage
#                     never silently redirects prod mail); with no EMAIL_DOMAIN it
#                     stays live, so existing setups are unaffected.
#   true            — always redirect.   false — never redirect.
# Set HOGSEND_TEST_EMAIL to choose the inbox (falls back to STUDIO_ADMIN_EMAIL).
# HOGSEND_TEST_MODE=auto
# HOGSEND_TEST_EMAIL=you@example.com

# Hatchet (self-hosted) — the bootstrap script mints this token for you. To do
# it manually, grab one from the dashboard (http://localhost:8888, login
# admin@example.com / Admin123!!). See docs.hogsend.com.
HATCHET_CLIENT_TOKEN=your-hatchet-token
HATCHET_CLIENT_HOST_PORT=localhost:7077
HATCHET_CLIENT_TLS_STRATEGY=none

# Public API URL — used for unsubscribe + tracking links in emails, and as the
# base URL for the data-plane client in src/lib/hogsend.ts.
API_PUBLIC_URL=http://localhost:3002

# Data-plane API key — authenticates calls from your own app code via the
# `@hogsend/client` instance in src/lib/hogsend.ts (PUT /v1/contacts,
# POST /v1/events, POST /v1/emails, /v1/lists). The key MUST carry the `ingest`
# scope (a `full-admin` key also implies it). `pnpm bootstrap` mints an
# ingest-scoped key for local dev and writes it here for you. In production,
# create one via POST /v1/admin/api-keys with scopes:["ingest"]. Deployed
# instances that never ran `pnpm bootstrap` (e.g. a Railway template deploy)
# mint one ingest-scoped key automatically on FIRST boot and print it to the
# deploy log ONCE — grab it from there. Opt out of that first-boot mint with
# HOGSEND_BOOTSTRAP_API_KEY=false.
HOGSEND_API_KEY=

# Journey filtering ("*" = all, or comma-separated journey IDs)
ENABLED_JOURNEYS=*

# Optional — PostHog event capture + person property WRITES (the phc_ project
# key handles both; person writes ride the capture pipeline as $set/$set_once)
# POSTHOG_API_KEY=phc_your_project_api_key
# POSTHOG_HOST=https://us.i.posthog.com

# Optional — PostHog person property READS (per-user timezone resolution,
# property conditions). The phc_ project key CANNOT read: it ships in every
# browser bundle, so PostHog makes it write-only — reads need a PERSONAL API
# key scoped `person:read` (PostHog → Settings → Personal API keys; scope it
# to your project). Without it, reads soft-fail and timezone resolution falls
# back to contact properties. Docs: https://hogsend.com/docs/guides/analytics-access
# POSTHOG_PERSONAL_API_KEY=your_personal_api_key
# Project id for the private API — discovered automatically when unset.
# POSTHOG_PROJECT_ID=12345
# Private (app) API host — derived from POSTHOG_HOST when unset
# (eu.i.posthog.com → eu.posthog.com). Set for self-hosted layouts.
# POSTHOG_PRIVATE_HOST=https://us.posthog.com

# Optional — verify incoming PostHog webhooks (POST /v1/webhooks/posthog)
# POSTHOG_WEBHOOK_SECRET=your-shared-secret

# Optional — verify Resend bounce/complaint webhooks
# RESEND_WEBHOOK_SECRET=whsec_your_signing_secret

# Optional — required for /v1/admin/* routes + CLI access
# ADMIN_API_KEY=your-admin-api-key

# Optional — integration presets (Clerk, Supabase, Stripe, Segment).
# Setting a preset's signing secret AUTO-ENABLES that source at
# POST /v1/webhooks/<id> — no code change needed (the engine mounts it for you).
# These are signature-verified sources: an unset secret means the source is NOT
# mounted; a configured-but-mismatched signature is rejected with 401.
# CLERK_WEBHOOK_SECRET=whsec_your_clerk_signing_secret
# SUPABASE_WEBHOOK_SECRET=whsec_your_supabase_signing_secret
# STRIPE_WEBHOOK_SECRET=whsec_your_stripe_endpoint_secret
# SEGMENT_WEBHOOK_SECRET=your_segment_shared_secret
#
# Override which presets enable: comma-separated ids (e.g. "stripe,clerk"),
# "*" (all presets whose secret is set), or "none" (disable all presets).
# Absent → auto-enable any preset whose secret above is configured.
# ENABLED_WEBHOOK_PRESETS=*

# Optional — outbound DESTINATION presets (event fan-out to product/data tools).
# A destination is a delivery-time transform keyed by webhook_endpoints.kind that
# reuses the engine's durable webhook delivery for a vendor projection. The
# `webhook` (default signed POST) and `posthog` presets are ALWAYS registered; set
# this to also register `segment` and/or `slack` so endpoints with those `kind`s
# resolve. Values: comma-separated ids (e.g. "segment,slack"), "*" (all presets),
# or "none" (presets webhook+posthog only). Absent → webhook+posthog only.
# Destination CREDENTIALS are NOT env vars — they live per-endpoint in
# webhook_endpoints.config (posthog: { apiKey, host? }, segment: { writeKey, host? },
# slack: { url }), managed via the admin API / `hs.webhooks` SDK.
# ENABLED_DESTINATION_PRESETS=segment,slack

# Optional — auto-seed ONE kind="posthog" destination subscribed to the email
# funnel so the full email lifecycle fans out to PostHog DURABLY (on the delivery
# spine). Requires POSTHOG_API_KEY. Default OFF to avoid a double-emit alongside
# the fire-and-forget PostHog capture path.
# ENABLE_POSTHOG_DESTINATION=true

# Cross-device identity stitch (optional): append an encrypted, one-hour
# `hs_t` token to tracked-link redirect destinations. Your landing site
# exchanges it at POST /v1/t/identify for the distinct id and calls
# posthog.identify — the email click and the web session become one person.
# Off by default: appending a parameter changes outbound URLs.
# TRACKING_IDENTITY_TOKEN=true
