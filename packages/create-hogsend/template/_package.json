{
  "name": "{{APP_NAME}}",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "bootstrap": "tsx scripts/bootstrap.ts",
    "dev": "tsx watch --include \"src/**\" --env-file=.env src/index.ts",
    "worker:dev": "tsx watch --include \"src/**\" --env-file=.env src/worker.ts",
    "studio:admin": "node --env-file=.env node_modules/@hogsend/cli/dist/bin.js studio admin create",
    "build": "tsup",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx --env-file-if-exists=.env scripts/migrate.ts",
    "seed:example-blueprint": "tsx --env-file-if-exists=.env scripts/seed-example-blueprint.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@hatchet-dev/typescript-sdk": "^1.22.3",
    "@hogsend/attribution": "^{{ENGINE_VERSION}}",
    "@hogsend/cli": "^{{ENGINE_VERSION}}",
    "@hogsend/client": "^{{ENGINE_VERSION}}",
    "@hogsend/core": "^{{ENGINE_VERSION}}",
    "@hogsend/db": "^{{ENGINE_VERSION}}",
    "@hogsend/email": "^{{ENGINE_VERSION}}",
    "@hogsend/engine": "^{{ENGINE_VERSION}}",
    "@hogsend/plugin-posthog": "^{{ENGINE_VERSION}}",
    "@hogsend/plugin-resend": "^{{ENGINE_VERSION}}",
    "@hogsend/studio": "^{{ENGINE_VERSION}}",
    "@hono/node-server": "^2.0.4",
    "@hono/zod-openapi": "^1.4.0",
    "@openrouter/ai-sdk-provider": "^2.9.1",
    "@scalar/hono-api-reference": "^0.10.19",
    "@t3-oss/env-core": "^0.13.11",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.22",
    "ioredis": "^5.10.1",
    "papaparse": "^5.5.3",
    "picocolors": "^1.1.1",
    "postgres": "^3.4.9",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "resend": "^6.12.3",
    "svix": "^1.95.1",
    "ai": "^6.0.209",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.15.3",
    "@types/papaparse": "^5.5.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.15",
    "drizzle-kit": "^0.31.10",
    "react-email": "^6.3.2",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "5.9.2",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22"
  }
}
