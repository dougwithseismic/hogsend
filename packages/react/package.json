{
  "name": "@hogsend/react",
  "version": "0.47.0",
  "type": "module",
  "license": "MIT",
  "description": "React hooks and components for Hogsend: provider, preferences, color mode, the notification feed, banners, and toasts.",
  "repository": {
    "type": "git",
    "url": "https://github.com/dougwithseismic/hogsend.git",
    "directory": "packages/react"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css",
    "./dist/styles/styles.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./feed": {
      "types": "./dist/feed.d.ts",
      "import": "./dist/feed.js",
      "require": "./dist/feed.cjs"
    },
    "./popover": {
      "types": "./dist/popover.d.ts",
      "import": "./dist/popover.js",
      "require": "./dist/popover.cjs"
    },
    "./bell": {
      "types": "./dist/bell.d.ts",
      "import": "./dist/bell.js",
      "require": "./dist/bell.cjs"
    },
    "./banner": {
      "types": "./dist/banner.d.ts",
      "import": "./dist/banner.js",
      "require": "./dist/banner.cjs"
    },
    "./toast": {
      "types": "./dist/toast.d.ts",
      "import": "./dist/toast.js",
      "require": "./dist/toast.cjs"
    },
    "./preferences": {
      "types": "./dist/preferences.d.ts",
      "import": "./dist/preferences.js",
      "require": "./dist/preferences.cjs"
    },
    "./styles.css": "./dist/styles/styles.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "biome check .",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "dependencies": {
    "@hogsend/js": "workspace:^"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@hogsend/core": "workspace:^",
    "@repo/typescript-config": "workspace:*",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.1"
  },
  "engines": {
    "node": ">=22"
  }
}
