{
  "name": "@hogsend/inspector",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Click any element in your running app to edit its text or static Tailwind classes in place, or open its exact source line. Dev-only, Next.js + Turbopack.",
  "repository": {
    "type": "git",
    "url": "https://github.com/dougwithseismic/hogsend.git",
    "directory": "packages/inspector"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "require": "./dist/server.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "loader",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "biome check .",
    "test": "node --no-warnings --experimental-strip-types --test test/*.test.mts",
    "clean": "rm -rf node_modules dist .turbo"
  },
  "dependencies": {
    "@babel/generator": "^8.0.0",
    "@babel/parser": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0"
  },
  "peerDependencies": {
    "react": "^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.5.1"
  },
  "engines": {
    "node": ">=22"
  }
}
