{
  "name": "@hogsend/db",
  "version": "0.17.0",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dougwithseismic/hogsend.git",
    "directory": "packages/db"
  },
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "files": [
    "src",
    "drizzle",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:migrate:client": "tsx src/migrate-client.ts",
    "db:push": "drizzle-kit push",
    "db:stamp": "tsx src/stamp.ts",
    "db:studio": "drizzle-kit studio",
    "db:pull": "drizzle-kit pull",
    "db:seed": "tsx src/seed.ts",
    "check-types": "tsc --noEmit"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.45.0"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:^",
    "@types/node": "^25.9.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.3"
  }
}
