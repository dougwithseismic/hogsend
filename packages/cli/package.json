{
  "name": "@hogsend/cli",
  "version": "0.31.1",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dougwithseismic/hogsend.git",
    "directory": "packages/cli"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": {
    "hogsend": "./dist/bin.js"
  },
  "exports": {
    ".": "./src/index.ts",
    "./eject": "./src/eject.ts",
    "./bin": "./dist/bin.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src",
    "skills",
    "studio",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node scripts/bundle-studio.mjs",
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "biome check .",
    "clean": "rm -rf node_modules dist .turbo",
    "test": "vitest run"
  },
  "devDependencies": {
    "@hogsend/studio": "workspace:^",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "@hogsend/db": "workspace:^",
    "@hogsend/engine": "workspace:^",
    "better-auth": "^1.6.11",
    "picocolors": "^1.1.1"
  }
}
