{
  "name": "@hogsend/js",
  "version": "0.47.0",
  "type": "module",
  "license": "MIT",
  "description": "Zero-dependency browser core SDK for Hogsend: identity, event capture, preferences, the in-app feed, banners, toasts, and the reactive store.",
  "repository": {
    "type": "git",
    "url": "https://github.com/dougwithseismic/hogsend.git",
    "directory": "packages/js"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./preferences": {
      "types": "./dist/preferences/index.d.ts",
      "import": "./dist/preferences/index.js",
      "require": "./dist/preferences/index.cjs"
    },
    "./feed": {
      "types": "./dist/feed/index.d.ts",
      "import": "./dist/feed/index.js",
      "require": "./dist/feed/index.cjs"
    },
    "./banner": {
      "types": "./dist/banner/index.d.ts",
      "import": "./dist/banner/index.js",
      "require": "./dist/banner/index.cjs"
    },
    "./toast": {
      "types": "./dist/toast/index.d.ts",
      "import": "./dist/toast/index.js",
      "require": "./dist/toast/index.cjs"
    },
    "./realtime": {
      "types": "./dist/realtime/index.d.ts",
      "import": "./dist/realtime/index.js",
      "require": "./dist/realtime/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "lint": "biome check .",
    "clean": "rm -rf node_modules dist .turbo",
    "test": "vitest run"
  },
  "devDependencies": {
    "@hogsend/core": "workspace:^",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "tsup": "^8.5.1",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22"
  }
}
