# =============================================================================
# Hogsend environment — canonical contract
# =============================================================================
# This file is the single annotated projection of the validated env schema in
# packages/engine/src/env.ts. Each var is tagged [required] / [default: x] /
# [optional]. Defaults shown are what the schema falls back to when the var is
# unset — you only need to set the [required] ones to boot.
#
# PORT REGIMES (mutually exclusive — pick one, do not mix):
#   * HOST-PROCESS DEV (you run `pnpm dev` / `pnpm worker` on your machine,
#     infra in `docker compose up -d`): reach services on their HOST-MAPPED
#     ports — postgres on :5434, redis on :6380, hatchet-lite on :7077. The
#     values in this file are set for THIS regime.
#   * IN-COMPOSE (api/worker run as compose services, e.g. the prod stack):
#     reach services by their IN-NETWORK names on their INTERNAL ports —
#     postgres:5432, redis:6379, hatchet-lite:7077. See the commented
#     in-network block under each affected var below.
# =============================================================================

# --- Core runtime ------------------------------------------------------------

# [default: development] one of: development | production | test
NODE_ENV=development

# [default: 3002] HTTP port the API listens on
PORT=3002

# [default: info] one of: error | warn | info | http | debug
LOG_LEVEL=debug

# --- Datastores --------------------------------------------------------------

# [required] Postgres (TimescaleDB) connection string.
# HOST-PROCESS DEV (host-mapped port):
DATABASE_URL=postgresql://growthhog:growthhog@localhost:5434/growthhog
# IN-COMPOSE (in-network name + internal port):
# DATABASE_URL=postgresql://growthhog:growthhog@postgres:5432/growthhog

# [default: redis://localhost:6379] Redis, used for PostHog property caching.
# HOST-PROCESS DEV (host-mapped port):
REDIS_URL=redis://localhost:6380
# IN-COMPOSE (in-network name + internal port):
# REDIS_URL=redis://redis:6379

# --- Auth (Better Auth) ------------------------------------------------------

# [required] Session-signing secret. MUST be a real random value — do NOT ship
# this placeholder. Generate one with: pnpm gen:secret  (openssl rand -base64 32)
# `pnpm bootstrap` generates this for you automatically into the created .env.
BETTER_AUTH_SECRET=REPLACE_ME_RUN_pnpm_gen:secret

# [default: http://localhost:3002] Public base URL Better Auth signs against.
BETTER_AUTH_URL=http://localhost:3002

# [optional] Extra origins allowed to call /api/auth, comma-separated. The API's
# own origin (API_PUBLIC_URL) and BETTER_AUTH_URL are always trusted. Set this
# when the Studio is served from a different origin than the API — e.g. the
# `hogsend studio` CLI pointing at a remote instance.
# BETTER_AUTH_TRUSTED_ORIGINS=https://studio.example.com

# --- Email (Resend) ----------------------------------------------------------

# [required] Resend API key.
RESEND_API_KEY=re_your_api_key_here

# [default: noreply@hogsend.com] Verified sender address.
RESEND_FROM_EMAIL=noreply@hogsend.com

# [optional] Resend webhook signing secret (bounce/complaint handling).
# RESEND_WEBHOOK_SECRET=whsec_your_signing_secret

# --- Hatchet (durable task orchestration) ------------------------------------
# Onboarding STEP 1 is "acquire a Hatchet". Hogsend connects to whatever you
# point it at via these three values — there is no auto-mint. Bring your own
# token: acquire HATCHET_CLIENT_TOKEN from Hatchet Cloud (create a tenant →
# generate an API token) or from the local hatchet-lite dashboard
# (http://localhost:8888 → log in → Settings → API Tokens) and paste it here.
# See docs/deployment-plan.md §3 for the three acquire paths.

# [required] Bearer JWT for the Hatchet engine. The SDK hard-throws if empty.
HATCHET_CLIENT_TOKEN=acquire-from-hatchet-cloud-or-the-hatchet-lite-dashboard

# [default: localhost:7077] gRPC address of the Hatchet engine.
# HOST-PROCESS DEV (host-mapped port):
HATCHET_CLIENT_HOST_PORT=localhost:7077
# IN-COMPOSE (in-network name + internal port):
# HATCHET_CLIENT_HOST_PORT=hatchet-lite:7077

# [default: tls] one of: none | tls | mtls. Secure by default (matches the SDK
# and Hatchet Cloud). The local insecure hatchet-lite path overrides to `none`.
HATCHET_CLIENT_TLS_STRATEGY=none

# [optional] Per-tenant isolation namespace (one shared engine, namespaced
# tasks). Default-empty today; documented so it stays part of the contract.
# HATCHET_CLIENT_NAMESPACE=

# --- PostHog (optional analytics integration) --------------------------------

# [optional] PostHog project API key. Without it, capture/identify are no-ops.
# POSTHOG_API_KEY=phc_your_project_key

# [optional] PostHog host (e.g. https://us.i.posthog.com).
# POSTHOG_HOST=https://us.i.posthog.com

# [optional] Shared secret for verifying incoming PostHog webhooks.
# POSTHOG_WEBHOOK_SECRET=your-shared-secret

# --- Admin & tracking --------------------------------------------------------

# [optional] Required for /v1/admin/* routes and CLI access.
# ADMIN_API_KEY=your-admin-api-key

# [default: http://localhost:3002] Public API URL used for unsubscribe links
# and first-party click/open tracking domains.
API_PUBLIC_URL=http://localhost:3002

# --- Journeys ----------------------------------------------------------------

# [default: *] Which journeys to load. "*" = all, or comma-separated IDs.
ENABLED_JOURNEYS=*

# --- Migrations / boot guard -------------------------------------------------

# [default: false] Emergency bypass for the API boot schema-version guard.
# Leave false unless you know exactly why you are skipping it.
# SKIP_SCHEMA_CHECK=false

# [optional] Override folder for the client migration track.
# CLIENT_MIGRATIONS_FOLDER=
