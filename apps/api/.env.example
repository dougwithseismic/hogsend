# =============================================================================
# Hogsend environment — canonical contract
# =============================================================================
# This file is the single annotated projection of the validated env schema in
# packages/engine/src/env.ts. Each var is tagged [required] / [default: x] /
# [optional]. Defaults shown are what the schema falls back to when the var is
# unset — you only need to set the [required] ones to boot.
#
# PORT REGIMES (mutually exclusive — pick one, do not mix):
#   * HOST-PROCESS DEV (you run `pnpm dev` / `pnpm worker` on your machine,
#     infra in `docker compose up -d`): reach services on their HOST-MAPPED
#     ports — postgres on :5434, redis on :6380, hatchet-lite on :7077. The
#     values in this file are set for THIS regime.
#   * IN-COMPOSE (api/worker run as compose services, e.g. the prod stack):
#     reach services by their IN-NETWORK names on their INTERNAL ports —
#     postgres:5432, redis:6379, hatchet-lite:7077. See the commented
#     in-network block under each affected var below.
# =============================================================================

# --- Core runtime ------------------------------------------------------------

# [default: development] one of: development | production | test
NODE_ENV=development

# [default: 3002] HTTP port the API listens on
PORT=3002

# [default: info] one of: error | warn | info | http | debug
LOG_LEVEL=debug

# --- Datastores --------------------------------------------------------------

# [required] Postgres (TimescaleDB) connection string.
# HOST-PROCESS DEV (host-mapped port):
DATABASE_URL=postgresql://growthhog:growthhog@localhost:5434/growthhog
# IN-COMPOSE (in-network name + internal port):
# DATABASE_URL=postgresql://growthhog:growthhog@postgres:5432/growthhog

# [default: redis://localhost:6379] Redis, used for PostHog property caching.
# HOST-PROCESS DEV (host-mapped port):
REDIS_URL=redis://localhost:6380
# IN-COMPOSE (in-network name + internal port):
# REDIS_URL=redis://redis:6379

# --- Auth (Better Auth) ------------------------------------------------------

# [required] Session-signing secret. MUST be a real random value — do NOT ship
# this placeholder. Generate one with: pnpm gen:secret  (openssl rand -base64 32)
# `pnpm bootstrap` generates this for you automatically into the created .env.
BETTER_AUTH_SECRET=REPLACE_ME_RUN_pnpm_gen:secret

# [default: http://localhost:3002] Public base URL Better Auth signs against.
BETTER_AUTH_URL=http://localhost:3002

# [optional] Extra origins allowed to call /api/auth, comma-separated. The API's
# own origin (API_PUBLIC_URL) and BETTER_AUTH_URL are always trusted. Set this
# when the Studio is served from a different origin than the API — e.g. the
# `hogsend studio` CLI pointing at a remote instance.
# BETTER_AUTH_TRUSTED_ORIGINS=https://studio.example.com

# [optional] First-admin bootstrap. Public sign-up is closed, so the first admin
# is created from the server: either set STUDIO_ADMIN_EMAIL here (on a zero-user
# DB the API mints it on boot) OR run `hogsend studio admin create`. If you set
# STUDIO_ADMIN_EMAIL but no STUDIO_ADMIN_PASSWORD, a strong password is generated
# and printed ONCE to the server log — rotate it via the Studio forgot/reset flow.
# STUDIO_ADMIN_EMAIL=admin@example.com
# STUDIO_ADMIN_PASSWORD=

# --- Email (Resend) ----------------------------------------------------------

# [required] Resend API key.
RESEND_API_KEY=re_your_api_key_here

# [default: noreply@hogsend.com] Verified sender address.
RESEND_FROM_EMAIL=noreply@hogsend.com

# [optional] Resend webhook signing secret (bounce/complaint handling).
# RESEND_WEBHOOK_SECRET=whsec_your_signing_secret

# --- SMS (Twilio) ------------------------------------------------------------
# Opt-in: with no Twilio creds the SMS service is an inert stub and sendSms
# throws an actionable error (email keeps working). Set the SID + token and ONE
# of SMS_FROM / TWILIO_MESSAGING_SERVICE_SID to enable the channel.

# [optional] Twilio Account SID + Auth Token (the auth token also verifies the
# X-Twilio-Signature on status/inbound webhooks).
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your_auth_token

# [optional] E.164 default sender. One of SMS_FROM / TWILIO_MESSAGING_SERVICE_SID
# is required for sends.
# SMS_FROM=+15551234567
# TWILIO_MESSAGING_SERVICE_SID=MGxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [default: twilio] Active SMS provider id resolved from the registry.
# SMS_PROVIDER=twilio

# [optional] Safe phone every send is redirected to while SMS test mode is
# armed (HOGSEND_TEST_MODE=true, or auto + the email side's test mode armed).
# HOGSEND_TEST_PHONE=+15557654321

# [default: true] First-party short-link rewriting: bare URLs in SMS bodies
# become <host>/s/<code> tracked links (a full tracking URL eats a third of a
# GSM-7 segment; carriers filter public shorteners). "false" disables.
# SMS_LINK_TRACKING=true

# [optional] Branded short domain the /s/<code> links serve from (must route to
# this app). Falls back to API_PUBLIC_URL.
# SMS_LINK_HOST=https://hs.example.com

# CONSENT: the sms channel is explicit opt-in (TCPA prior express consent) —
# marketing SMS needs a per-contact grant (POST /v1/lists/sms/subscribe, the
# SDK, the preference center, or an inbound START). Transactional templates
# send without a grant but never bypass the STOP list.

# Wire Twilio's Messaging Service (or number) status callback + inbound webhook
# to: <API_PUBLIC_URL>/v1/webhooks/sms/twilio

# --- Hatchet (durable task orchestration) ------------------------------------
# Onboarding STEP 1 is "acquire a Hatchet". Hogsend connects to whatever you
# point it at via these three values — there is no auto-mint. Bring your own
# token: acquire HATCHET_CLIENT_TOKEN from Hatchet Cloud (create a tenant →
# generate an API token) or from the local hatchet-lite dashboard
# (http://localhost:8888 → log in → Settings → API Tokens) and paste it here.
# See docs/deployment-plan.md §3 for the three acquire paths.

# [required] Bearer JWT for the Hatchet engine. The SDK hard-throws if empty.
HATCHET_CLIENT_TOKEN=acquire-from-hatchet-cloud-or-the-hatchet-lite-dashboard

# [default: localhost:7077] gRPC address of the Hatchet engine.
# HOST-PROCESS DEV (host-mapped port):
HATCHET_CLIENT_HOST_PORT=localhost:7077
# IN-COMPOSE (in-network name + internal port):
# HATCHET_CLIENT_HOST_PORT=hatchet-lite:7077

# [default: tls] one of: none | tls | mtls. Secure by default (matches the SDK
# and Hatchet Cloud). The local insecure hatchet-lite path overrides to `none`.
HATCHET_CLIENT_TLS_STRATEGY=none

# [optional] Per-tenant isolation namespace (one shared engine, namespaced
# tasks). Default-empty today; documented so it stays part of the contract.
# HATCHET_CLIENT_NAMESPACE=

# --- PostHog (optional analytics integration) --------------------------------

# [optional] PostHog project API key. Without it, capture/identify are no-ops.
# POSTHOG_API_KEY=phc_your_project_key

# [optional] PostHog host (e.g. https://us.i.posthog.com).
# POSTHOG_HOST=https://us.i.posthog.com

# [optional] Shared secret for verifying incoming PostHog webhooks.
# POSTHOG_WEBHOOK_SECRET=your-shared-secret

# --- Admin & tracking --------------------------------------------------------

# [optional] Required for /v1/admin/* routes and CLI access.
# ADMIN_API_KEY=your-admin-api-key

# [default: http://localhost:3002] Public API URL used for unsubscribe links
# and first-party click/open tracking domains.
API_PUBLIC_URL=http://localhost:3002

# --- Discord connector (optional) --------------------------------------------
# Inbound Discord activity (messages/reactions/joins/presence) → IngestEvents
# via a long-lived Gateway worker (`pnpm discord:dev` / `pnpm discord:worker`),
# plus a one-click connect + per-member link flow. Leave unset to disable
# Discord entirely (the connector simply isn't registered). The app secrets can
# ALSO be stored encrypted via `hogsend connect discord`; these env vars are the
# deploy-time mirror the gateway worker reads at boot.
#
# From the Discord Developer Portal (https://discord.com/developers/applications):
#   Bot tab        → Reset Token (DISCORD_BOT_TOKEN); enable the three privileged
#                    intents: SERVER MEMBERS, MESSAGE CONTENT, PRESENCE.
#   OAuth2 tab     → CLIENT ID (=DISCORD_APPLICATION_ID) + CLIENT SECRET; add the
#                    redirect ${API_PUBLIC_URL}/v1/connectors/discord/oauth/callback
#   General Info   → PUBLIC KEY (DISCORD_PUBLIC_KEY, ed25519 hex)
#   Interactions Endpoint URL → ${API_PUBLIC_URL}/v1/connectors/discord/interactions

# [optional] Bot token — Gateway login + bot-REST.
# DISCORD_BOT_TOKEN=your-bot-token
# [optional] OAuth2 application (client) id.
# DISCORD_APPLICATION_ID=your-application-id
# [optional] OAuth2 client secret (server-side code exchange only).
# DISCORD_CLIENT_SECRET=your-client-secret
# [optional] Ed25519 public key (hex) — interaction signature verification.
# DISCORD_PUBLIC_KEY=your-public-key-hex
# [optional] Default guild id (populated after the bot is installed).
# DISCORD_GUILD_ID=

# [optional] Shared internal secret for the gateway-worker → connector ingress
# hop (POST /v1/connectors/:id/ingress). MUST be >=32 chars and high-entropy —
# generate with: openssl rand -base64 32. Fail-CLOSED: the ingress route 401s
# when unset, so the gateway worker cannot relay events without it.
# CONNECTOR_INGRESS_SECRET=

# NOTE: for a LOCAL end-to-end run behind a cloudflared tunnel, set API_PUBLIC_URL
# (below) to the public https tunnel URL — Discord PINGs the interactions
# endpoint synchronously when you save it, and the gateway worker forwards to
# ${API_PUBLIC_URL}/v1/connectors/discord/ingress, so it must be publicly
# reachable (not loopback).

# --- Journeys ----------------------------------------------------------------

# [default: *] Which journeys to load. "*" = all, or comma-separated IDs.
ENABLED_JOURNEYS=*

# --- Migrations / boot guard -------------------------------------------------

# [default: false] Emergency bypass for the API boot schema-version guard.
# Leave false unless you know exactly why you are skipping it.
# SKIP_SCHEMA_CHECK=false

# [optional] Override folder for the client migration track.
# CLIENT_MIGRATIONS_FOLDER=
