NODE_ENV=development
PORT=3002
LOG_LEVEL=debug
DATABASE_URL=postgresql://growthhog:growthhog@localhost:5432/growthhog
REDIS_URL=redis://localhost:6379
BETTER_AUTH_SECRET=your-secret-here-minimum-32-characters
BETTER_AUTH_URL=http://localhost:3002
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@hogsend.com

# Hatchet (self-hosted)
HATCHET_CLIENT_TOKEN=your-hatchet-token
HATCHET_CLIENT_HOST_PORT=localhost:7077
HATCHET_CLIENT_TLS_STRATEGY=none

# PostHog webhook (optional, for verifying incoming webhooks)
# POSTHOG_WEBHOOK_SECRET=your-shared-secret

# Journey filtering ("*" = all, or comma-separated IDs)
ENABLED_JOURNEYS=*
