{
  "name": "@hogsend/api",
  "version": "0.0.36",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "worker:dev": "tsx watch --env-file=.env src/worker.ts",
    "discord:worker": "node dist/discord-worker.js",
    "discord:dev": "tsx watch --env-file=.env src/discord-worker.ts",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "tsx --env-file=.env scripts/smoke.ts",
    "discord:register-commands": "tsx --env-file=.env scripts/register-discord-commands.ts",
    "telegram:link": "tsx --env-file=.env scripts/mk-telegram-link.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.85",
    "@hatchet-dev/typescript-sdk": "^1.22.3",
    "@hogsend/core": "workspace:^",
    "@hogsend/db": "workspace:^",
    "@hogsend/email": "workspace:^",
    "@hogsend/engine": "workspace:^",
    "@hogsend/plugin-discord": "workspace:^",
    "@hogsend/plugin-posthog": "workspace:^",
    "@hogsend/plugin-resend": "workspace:^",
    "@hogsend/plugin-telegram": "workspace:^",
    "@hono/node-server": "^2.0.4",
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.10.19",
    "@t3-oss/env-core": "^0.13.11",
    "ai": "^6.0.208",
    "better-auth": "^1.6.11",
    "discord.js": "^14.26.4",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.22",
    "ioredis": "^5.10.1",
    "papaparse": "^5.5.3",
    "react": "^19.2.6",
    "react-dom": "19.2.6",
    "react-email": "6.3.2",
    "resend": "^6.12.3",
    "winston": "^3.19.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@hogsend/js": "workspace:^",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.15",
    "posthog-node": "^5.35.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22"
  }
}
