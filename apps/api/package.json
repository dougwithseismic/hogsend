{
  "name": "@hogsend/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "worker": "node dist/worker.js",
    "worker:dev": "tsx watch --env-file=.env src/worker.ts",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hatchet-dev/typescript-sdk": "^1.22.3",
    "@hogsend/core": "workspace:^",
    "@hogsend/db": "workspace:^",
    "@hogsend/email": "workspace:^",
    "@hogsend/plugin-posthog": "workspace:^",
    "@hogsend/plugin-resend": "workspace:^",
    "@hono/node-server": "^2.0.4",
    "@hono/zod-openapi": "^1.4.0",
    "@scalar/hono-api-reference": "^0.10.19",
    "@t3-oss/env-core": "^0.13.11",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.22",
    "react": "^19.2.6",
    "resend": "^6.12.3",
    "winston": "^3.19.0",
    "ioredis": "^5.10.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.15.3",
    "@types/react": "^19.2.15",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "vitest": "^4.1.7"
  },
  "engines": {
    "node": ">=22"
  }
}
