# Email capture → Hogsend ingest (server-only; never expose via NEXT_PUBLIC_*).
# Base URL of the Hogsend instance the docs site forwards `docs.subscribed`
# events to, e.g. http://localhost:3002 or https://api.example.com
HOGSEND_INGEST_URL=

# Ingest-scoped API key sent as `Authorization: Bearer <key>`.
# With either var unset, POST /api/subscribe answers 503 (capture disabled).
HOGSEND_INGEST_KEY=

# Shared secret for the anonymous referral-visit webhook (sent as the
# `x-referral-secret` header to {HOGSEND_INGEST_URL}/v1/webhooks/referral-visited).
# Must equal the dogfood's REFERRAL_WEBHOOK_SECRET. Unset ⇒ /api/referral-visited
# answers 503. The /hey ?ref attribution is disabled until both sides are set.
HOGSEND_REFERRAL_SECRET=

# Optional — PostHog EU project key; analytics are cookieless and disabled when unset.
NEXT_PUBLIC_POSTHOG_KEY=

# Services checkout → Stripe (server-only; never expose via NEXT_PUBLIC_*).
# Secret key of the SAME Stripe account the course uses. Its presence is the
# checkout on/off switch: with it unset, POST /api/checkout falls back to the
# booking form and the paid CTAs never dead-end.
STRIPE_SECRET_KEY=

# Stripe Price ids for the two self-serve tiers, created in that account:
#   - Managed: a $149/month RECURRING price
#   - Setup week: a $2,300 ONE-TIME price
# An unset var makes that tier non-purchasable (CTA falls back to booking).
STRIPE_PRICE_SERVICE_MANAGED=
STRIPE_PRICE_SERVICE_SETUP=

# NOTE: the paid closing signal (`service.purchased` → the services funnel) is
# verified + emitted by the dogfood `stripe-services` webhook, NOT this site.
# Point the Stripe webhook at {dogfood}/webhooks/stripe-services and set
# STRIPE_SERVICES_WEBHOOK_SECRET (+ STRIPE_SERVICES_PRICE_MAP for renewals) there.
