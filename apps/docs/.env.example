# Email capture → Hogsend ingest (server-only; never expose via NEXT_PUBLIC_*).
# Base URL of the Hogsend instance the docs site forwards `docs.subscribed`
# events to, e.g. http://localhost:3002 or https://api.example.com
HOGSEND_INGEST_URL=

# Ingest-scoped API key sent as `Authorization: Bearer <key>`.
# With either var unset, POST /api/subscribe answers 503 (capture disabled).
HOGSEND_INGEST_KEY=

# Shared secret for the anonymous referral-visit webhook (sent as the
# `x-referral-secret` header to {HOGSEND_INGEST_URL}/v1/webhooks/referral-visited).
# Must equal the dogfood's REFERRAL_WEBHOOK_SECRET. Unset ⇒ /api/referral-visited
# answers 503. The /hey ?ref attribution is disabled until both sides are set.
HOGSEND_REFERRAL_SECRET=

# Optional — PostHog EU project key; analytics are cookieless and disabled when unset.
NEXT_PUBLIC_POSTHOG_KEY=

# Services checkout + portal — this site holds NO Stripe secret. POST
# /api/checkout forwards the tier + session-verified email to the Hono API's
# POST /checkout, and the /portal page reads the customer's services + live
# subscription state from POST /me/services (both at HOGSEND_INGEST_URL, above)
# over this shared bearer, which must equal SERVICE_CHECKOUT_SECRET on the API
# service. Unset ⇒ buy CTAs fall back to the booking form and the portal shows
# a soft "couldn't load" state. All Stripe config — secret key, price ids,
# webhook secret — lives on the API service, not here.
# SCOPE NOTE: this bearer authorizes checkout-session creation AND
# customer-scoped billing reads/operations on the API — treat it as
# high-value and rotate it (on BOTH services) on any suspicion of exposure.
SERVICE_CHECKOUT_SECRET=
