{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hogsend",
  "version": "0.1.0",
  "identifier": "com.hogsend.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:5174",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Hogsend",
        "width": 380,
        "height": 600,
        "minWidth": 340,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "shortDescription": "Menubar companion for the Hogsend lifecycle engine",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/dougwithseismic/hogsend/releases/download/desktop-latest/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE1MjdFODNFREExQzA2ODMKUldTREJoemFQdWduRlRqaHYvcWFoRENOVkFKb0lGUWNUVy90ZzhGcWRob0JJVU5LbW85eS9Jbi8K"
    }
  }
}
